# GitHub OAuth App credentials — create one at https://github.com/settings/developers
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret

# Token for the fetch_issues.py CLI script (needs repo read access)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret key for signing session cookies (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET=change_me_to_a_random_string

# SQLite database path (relative to project root)
DATABASE_URL=sqlite+aiosqlite:///./issuematch.db

# Base URL of the app (must match what you registered in the GitHub OAuth App)
BASE_URL=http://localhost:8000
